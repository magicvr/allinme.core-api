{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/magicvr/goal-governance/schema/skills-consumer-compatibility-matrix/v1",
  "title": "Goal Governance Skills Consumer Compatibility Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "format",
    "formatVersion",
    "candidateRevision",
    "canonicalContractPath",
    "protocol",
    "requiredEntrypoints",
    "negativeFixtures",
    "consumers"
  ],
  "properties": {
    "schemaId": {
      "const": "https://github.com/magicvr/goal-governance/schema/skills-consumer-compatibility-matrix/v1"
    },
    "format": {
      "const": "goal-governance.skills-consumer-compatibility-matrix"
    },
    "formatVersion": {
      "$ref": "#/$defs/semver"
    },
    "candidateRevision": {
      "type": "string",
      "description": "Use 'unreleased' while developing, a full Git commit for a commit-bound rehearsal, or the exact annotated v-prefixed SemVer tag for release-candidate evidence.",
      "pattern": "^(?:unreleased|[0-9a-f]{40}|v(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?)$"
    },
    "canonicalContractPath": {
      "const": "docs/contracts/skills-consumer-contract.json"
    },
    "protocol": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current", "previous", "previousStatus"],
      "properties": {
        "current": { "$ref": "#/$defs/semver" },
        "previous": {
          "anyOf": [
            { "$ref": "#/$defs/semver" },
            { "type": "null" }
          ]
        },
        "previousStatus": {
          "enum": ["supported", "not-applicable-first-supported-protocol"]
        }
      }
    },
    "requiredEntrypoints": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": { "type": "string" }
    },
    "negativeFixtures": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/negativeFixture" }
    },
    "consumers": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/consumer" }
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "semverRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minInclusive", "maxExclusive"],
      "properties": {
        "minInclusive": { "$ref": "#/$defs/semver" },
        "maxExclusive": { "$ref": "#/$defs/semver" }
      }
    },
    "negativeFixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "path", "assertion"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": {
          "enum": ["unsupported-protocol", "fabricated-predecessor"]
        },
        "path": {
          "type": "string",
          "pattern": "^docs/contracts/fixtures/(valid|invalid)/.+\\.json$"
        },
        "assertion": { "type": "string", "minLength": 1 }
      }
    },
    "host": {
      "type": "object",
      "additionalProperties": false,
      "required": ["product", "version", "platform", "installationSurface"],
      "properties": {
        "product": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "platform": { "type": "string", "minLength": 1 },
        "installationSurface": { "type": "string", "minLength": 1 },
        "build": { "type": "string" },
        "commit": { "type": "string" },
        "packageSha256": {
          "type": "string",
          "pattern": "^[0-9A-Fa-f]{64}$"
        }
      }
    },
    "entrypoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "evidence"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "status": {
          "enum": [
            "pending-runtime-validation",
            "runtime-verified",
            "blocked",
            "pending-ci-replay",
            "automated-verified",
            "not-applicable"
          ]
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "consumer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "host",
        "supportsProtocol",
        "supportCommitment",
        "contractVerificationStatus",
        "entrypoints",
        "evidenceScope"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["host-adapter", "goal-document-parser"] },
        "host": { "$ref": "#/$defs/host" },
        "supportsProtocol": { "$ref": "#/$defs/semverRange" },
        "supportCommitment": {
          "enum": ["declared", "committed", "not-applicable"]
        },
        "contractVerificationStatus": {
          "enum": ["unverified", "verified", "not-applicable"]
        },
        "entrypoints": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/entrypoint" }
        },
        "evidenceScope": { "type": "string", "minLength": 1 }
      }
    }
  }
}
